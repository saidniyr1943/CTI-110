def passwordChecker(s):
    """Returns True if the password has at least 8 characters, one letter, and one digit."""
    hasLetter = False
    hasDigit = False

    for ch in s:
        if ch.isalpha():
            hasLetter = True
        if ch.isdigit():
            hasDigit = True

    if len(s) >= 8 and hasLetter and hasDigit:
        return True
    else:
        return False





def divisibleByFirstTwo(lst):
    """Returns values from index 2 onward that are divisible by both of the first two list values."""
    n1 = lst[0]
    n2 = lst[1]
    result = []

    for i in range(2, len(lst)):
        if lst[i] % n1 == 0 and lst[i] % n2 == 0:
            result.append(lst[i])

    return result





def increaseValues(lst, num):
    """Adds num to each value in the list by changing the original list."""
    for i in range(len(lst)):
        lst[i] = lst[i] + num
